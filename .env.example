# Dialtone — Configuration
# Copy this to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════
# Twilio (Required)
# ═══════════════════════════════════════════════════════════════════
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+123****7890

# ═══════════════════════════════════════════════════════════════════
# STT Provider (Speech-to-Text)
# ═══════════════════════════════════════════════════════════════════
# Options: deepgram, assemblyai, google, azure, whisper, groq, speechmatics, local
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=your_deepgram_key
# ASSEMBLYAI_API_KEY=
# GROQ_API_KEY=
# SPEECHMATICS_API_KEY=
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=eastus

# ═══════════════════════════════════════════════════════════════════
# TTS Provider (Text-to-Speech)
# ═══════════════════════════════════════════════════════════════════
# Options: polly, elevenlabs, openai, azure, google, cartesia, deepgram_aura, kokoro, edge, mimo
TTS_PROVIDER=polly
TTS_VOICE=Polly.Brian
TTS_LANGUAGE=en-GB
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# CARTESIA_API_KEY=
# CARTESIA_VOICE_ID=

# ═══════════════════════════════════════════════════════════════════
# Agent Backend (AI / LLM)
# ═══════════════════════════════════════════════════════════════════
# Options: (empty=auto-detect), hermes-gateway, openai, xiaomi, openrouter, ollama, lmstudio
# Leave empty to auto-detect: tries Hermes Gateway first, then legacy LLM fallback.
AGENT_PROVIDER=

# Hermes Gateway (recommended — wraps your Hermes agent with tools + memory)
HERMES_GATEWAY_URL=http://127.0.0.1:8642
HERMES_GATEWAY_TOKEN=your_gateway_token_here
# HERMES_MODEL_OVERRIDE=  # Leave empty to use agent default, or set e.g. "anthropic/claude-sonnet-4"

# Legacy LLM (fallback if Hermes Gateway not available)
LLM_PROVIDER=xiaomi
LLM_MODEL=mimo-v2.5
# XIAOMI_API_KEY=
# XIAOMI_BASE_URL=https://token-plan-ams.xiaomimimo.com/v1
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENROUTER_API_KEY=

# ═══════════════════════════════════════════════════════════════════
# Phone Agent Settings
# ═══════════════════════════════════════════════════════════════════
COMPANY_NAME="My Company"
VOICEMAIL_EMAIL=hello@company.com
VOICEMAIL_PIN=1234
VOICEMAIL_MAX_LENGTH=120
# VOICEMAIL_GREETING=  # Leave empty for default

# ═══════════════════════════════════════════════════════════════════
# AI Agent
# ═══════════════════════════════════════════════════════════════════
CALL_GOAL="Have a helpful conversation."
# CALL_SYSTEM_PROMPT=  # Leave empty for default

# ═══════════════════════════════════════════════════════════════════
# Voice Engine (Local on Apple Silicon)
# ═══════════════════════════════════════════════════════════════════
# Options: auto, true, false
USE_LOCAL_VOICE=auto

# ═══════════════════════════════════════════════════════════════════
# Telegram (Optional — voicemail notifications)
# ═══════════════════════════════════════════════════════════════════
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════════════════════════
# Network
# ═══════════════════════════════════════════════════════════════════
# WEBHOOK_URL_OVERRIDE=  # Use if behind a proxy (e.g. https://phone.example.com)
WEBHOOK_PORT=5050
DASHBOARD_PORT=5051

# ═══════════════════════════════════════════════════════════════════
# Dashboard Security (auto-generated by installer)
# ═══════════════════════════════════════════════════════════════════
DASHBOARD_TOKEN=your_secret_token_here
