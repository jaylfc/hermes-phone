# ╔══════════════════════════════════════════════════════════════════╗
# ║  Hermes Phone — Configuration                                  ║
# ║  Copy this to .env and fill in your values                     ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Twilio ─────────────────────────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+443xxxxxxxxx

# ── Deepgram (Speech-to-Text) ──────────────────────────────────────
# Free $200 credit at https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_key_here

# ── LLM (any OpenAI-compatible API) ───────────────────────────────
# Option 1: OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Option 2: Xiaomi MiMo (free tier)
# XIAOMI_API_KEY=your_xiaomi_key
# XIAOMI_BASE_URL=https://token-plan-ams.xiaomimimo.com/v1
# LLM_PROVIDER=xiaomi
# LLM_MODEL=mimo-v2.5

# Option 3: OpenRouter (100+ models)
# OPENROUTER_API_KEY=sk-or-xxxx
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LLM_PROVIDER=openrouter
# LLM_MODEL=anthropic/claude-sonnet-4

# Option 4: Local (Ollama)
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3

# ── Phone Agent Settings ──────────────────────────────────────────
# PIN to bypass voicemail and reach AI (callers dial this during greeting)
VOICEMAIL_PIN=1234

# Company name for the greeting
COMPANY_NAME=Your Company Name

# Email to mention in the voicemail greeting
VOICEMAIL_EMAIL=hello@yourcompany.com

# Max voicemail length in seconds
VOICEMAIL_MAX_LENGTH=120

# ── Telegram Notifications (Optional) ─────────────────────────────
# Get your bot token from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=your_chat_id

# ── Call Settings ──────────────────────────────────────────────────
# System prompt for the AI during calls
# CALL_SYSTEM_PROMPT=You are a helpful assistant for JAN Labs. Be concise and professional.
CALL_GOAL=Have a helpful conversation.

# ── Local Voice (Apple Silicon MLX) ────────────────────────────────
# Auto-detect local models, fall back to cloud if not available
# Set to "true" to require local models (will install if missing)
# Set to "false" to force cloud TTS/STT
USE_LOCAL_VOICE=auto
