#!/usr/bin/env bash
# Dialtone — .env template
# Copy this to .env and fill in your keys
#

# Twilio (https://console.twilio.com)
export TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
export TWILIO_AUTH_TOKEN="your-auth-token"
export TWILIO_PHONE_NUMBER="+123****7890"

# Your phone number (for outbound calls)
export MY_PHONE_NUMBER="+098****4321"

# ─── AI: OFFLINE BY DEFAULT — no API keys needed (only Twilio above) ───
# LLM runs locally via Ollama (https://ollama.com). Installer picks by Mac RAM:
#   16GB → qwen3:8b   ·   24GB → qwen3:14b   ·   48GB+ → qwen3:32b
export AGENT_PROVIDER="ollama"
export LLM_MODEL="qwen3:8b"
# export OLLAMA_BASE_URL="http://localhost:11434/v1"

# Voice runs locally on Apple Silicon (mlx-whisper STT + Kokoro TTS) — no keys
export STT_PROVIDER="whisper"
export TTS_PROVIDER="kokoro"
export USE_LOCAL_VOICE="auto"            # auto | true | false
export TTS_VOICE="Polly.Brian"           # Twilio <Say> greeting voice
export TTS_LANGUAGE="en-GB"

# Prefer cloud? Comment the local lines above and uncomment one set below:
# export AGENT_PROVIDER="openai"; export LLM_API_KEY_OVERRIDE="sk-..."; export LLM_MODEL_OVERRIDE="gpt-4o-mini"
# export STT_PROVIDER="deepgram"; export DEEPGRAM_API_KEY="your-key"   # https://console.deepgram.com/signup
# export TTS_PROVIDER="elevenlabs"; export ELEVENLABS_API_KEY="your-key"

# Call handling
export COMPANY_NAME="My Company"
export VOICEMAIL_EMAIL="hello@company.com"
export VOICEMAIL_PIN="1234"
export CALL_GOAL="Have a friendly conversation."

# Dashboard security (auto-generated if empty)
# export DASHBOARD_TOKEN=""

# Remote client: run the menu bar on another machine pointed at this server.
# On the CLIENT set HERMES_SERVER_URL + the same DASHBOARD_TOKEN as the server:
# export HERMES_SERVER_URL="http://your-server-host:5051"

# Telegram notifications (optional)
# export TELEGRAM_BOT_TOKEN=""
# export TELEGRAM_CHAT_ID=""
